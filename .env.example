# Database
DATABASE_URL="postgresql://user:password@host:6543/db?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:password@host:5432/db"

# DEV-only: allow self-signed TLS (e.g. Supabase pooler)
PRISMA_PG_ACCEPT_SELF_SIGNED=false
# Alternative flag (also DEV-only)
# PG_SSL_REJECT_UNAUTHORIZED=false

# Auth (GitHub OAuth)
GITHUB_ID=""
GITHUB_SECRET=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
ADMIN_GITHUB_LOGINS="login1,login2"

# Vercel Blob
BLOB_READ_WRITE_TOKEN=""

# Contact form email
RESEND_API_KEY=""
CONTACT_TO_EMAIL=""
CONTACT_FROM_EMAIL="Portfolio Contact <onboarding@resend.dev>"

# OpenAI
OPENAI_API_KEY="replace_me"
OPENAI_TRANSLATE_MODEL="gpt-4o-mini"
